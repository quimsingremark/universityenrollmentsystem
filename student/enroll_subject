    <title>Pre-Register Subjects</title>
    <link rel="stylesheet" href="../css/style.css">
</head>
<body>
<div class="form-container wide-form">
    <a class="back-link" href="dashboard.php">&larr; Back to Dashboard</a>
    <h1>Pre-Register Current Semester Subjects</h1>
    <p>Showing only <?php echo htmlspecialchars($program); ?> Year <?php echo htmlspecialchars($year_level); ?> - Semester <?php echo htmlspecialchars($semester_level); ?> subject sections.</p>
    <p class="help-text">Choose subject sections. Your choices will stay pending until the registrar confirms your pre-registration.</p>
    <?php if($message): ?><div class="message"><?php echo $message; ?></div><?php endif; ?>
    <form method="POST">
        <label>Select Subject Sections</label>
        <div class="checkbox-subject-list">
            <?php if($sectionResult->num_rows > 0): ?>
                <?php while($row = $sectionResult->fetch_assoc()): ?>
                    <label class="subject-checkbox-card">
                        <input type="checkbox" name="section_ids[]" value="<?php echo $row['section_id']; ?>">
                        <div>
                            <strong><?php echo htmlspecialchars($row['course_code']); ?></strong>
                            <span><?php echo htmlspecialchars($row['title']); ?></span>
                            <small><?php echo htmlspecialchars($row['credits'].' units | Section: '.$row['section'].' | Professor: '.$row['professor_name'].' | Prereq: '.($row['pre_code'] ?? 'None')); ?></small>
                        </div>
                    </label>
                <?php endwhile; ?>
            <?php else: ?>
                <p class="empty">No subject sections available. Ask the registrar to assign subjects to professors and sections first.</p>
            <?php endif; ?>
        </div>
        <button type="submit" name="submit">Send Pre-Registration to Registrar</button>
    </form>
